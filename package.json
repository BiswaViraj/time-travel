{
  "name": "@biswaviraj/time-travel",
  "version": "2.0.5",
  "description": "Simple and lightweight undo redo package",
  "engines": {
    "node": ">=20.19.0"
  },
  "packageManager": "pnpm@10.32.1",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "browser": "./dist/index.mjs",
  "react-native": "./dist/index.mjs",
  "unpkg": "./dist/index.iife.js",
  "jsdelivr": "./dist/index.iife.js",
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "default": "./dist/index.mjs"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --ext .ts",
    "build": "tsdown",
    "build:watch": "tsdown --watch"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/BiswaViraj/time-travel.git"
  },
  "author": "BiswaViraj",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/BiswaViraj/time-travel/issues"
  },
  "homepage": "https://github.com/BiswaViraj/time-travel#readme",
  "keywords": [
    "undo",
    "redo",
    "history",
    "time travel",
    "time-travel",
    "state history",
    "rollback"
  ],
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.0.1",
    "@typescript-eslint/parser": "^8.0.1",
    "eslint": "^9.9.0",
    "tsdown": "^0.21.6",
    "typescript": "^5.5.4"
  }
}
