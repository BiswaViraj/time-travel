{
	"compilerOptions": {
		"declaration": true,
		"declarationMap": true,
		"esModuleInterop": true,
		"isolatedDeclarations": true,
		"jsx": "react-jsx",
		"lib": ["ES2020", "DOM"],
		"module": "ESNext",
		"moduleResolution": "Bundler",
		"noEmit": true,
		"skipLibCheck": true,
		"target": "ES2020"
	},
	"include": ["src"]
}
